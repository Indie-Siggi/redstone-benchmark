+        if (CliInt  (L"-scalepreset=",       i)) { m_ScalePreset = static_cast<FSRScalePreset>(i); benchApplyPreset = true; }
+        if (CliFloat(L"-upscaleratio=",      f)) { m_UpscaleRatio = f; benchApplyPreset = true; }
+        if (CliBool (L"-framegen=",          b)) { m_FrameInterpolation = b; benchApplyPreset = true; }
+        // Read per-frame — a member set is enough
+        if (CliBool (L"-rcas=",              b)) m_RCASSharpen = b;
+        if (CliFloat(L"-sharpness=",         f)) m_Sharpness = f;
