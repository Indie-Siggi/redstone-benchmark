+        if (CliBool (L"-fgpacinglines=",     b)) m_DrawFrameGenerationDebugPacingLines = b;
+        if (CliBool (L"-fgresetindicators=", b)) m_DrawFrameGenerationDebugResetIndicators = b;
+        if (CliBool (L"-fgdebugview=",       b)) m_DrawFrameGenerationDebugView = b;
+        if (CliBool (L"-presentinterponly=", b)) m_PresentInterpolatedOnly = b;
+        if (CliBool (L"-doublebufferui=",    b)) m_DoublebufferInSwapchain = b;
+        if (CliBool (L"-allowasynccompute=", b)) m_AllowAsyncCompute = b;
+        // Read at context creation (set before SwitchUpscaler so the initial context uses them)
