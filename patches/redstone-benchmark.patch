+// command line is already echoed into the -benchmark CSV/JSON, so each run is
+// self-describing.
+// ---------------------------------------------------------------------------
+namespace
+{
+    bool CliRawValue(const wchar_t* key, std::wstring& outVal)
+    {
+        std::wstring cmd = GetCommandLineW();
+        std::wstring k(key);
+        size_t pos = cmd.find(k);
+        if (pos == std::wstring::npos)
+            return false;
+        pos += k.size();
+        size_t end = cmd.find_first_of(L" \t", pos);
+        outVal = cmd.substr(pos, end == std::wstring::npos ? std::wstring::npos : end - pos);
+        return true;
+    }
+    bool CliInt(const wchar_t* key, int32_t& out)
+    {
+        std::wstring v;
+        if (!CliRawValue(key, v) || v.empty()) return false;
+        out = static_cast<int32_t>(wcstol(v.c_str(), nullptr, 10));
+        return true;
+    }
+    bool CliFloat(const wchar_t* key, float& out)
+    {
+        std::wstring v;
+        if (!CliRawValue(key, v) || v.empty()) return false;
+        out = static_cast<float>(wcstod(v.c_str(), nullptr));
+        return true;
+    }
+    bool CliBool(const wchar_t* key, bool& out)
+    {
+        int32_t i;
+        if (!CliInt(key, i)) return false;
+        out = (i != 0);
+        return true;
+    }
+}
 
